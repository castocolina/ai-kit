## ═══════════════════════════════════════════════════════════════════════════
## ai-kit status line — configuration recipe
## ═══════════════════════════════════════════════════════════════════════════
## Location: ~/.config/ai-kit/statusline.toml
##   (or $XDG_CONFIG_HOME/ai-kit/statusline.toml when XDG_CONFIG_HOME is set;
##    or any path you point $CC_AI_KIT_CONFIG at).
## The installer drops this file there if you don't already have one, and never
## overwrites an existing one.
##
## As shipped EVERY line below is commented out, so this file is a NO-OP and the
## built-in defaults apply. Uncomment only the lines you want to change — the
## value shown on each line IS the current default, so nothing is left to guess.
##
## Precedence (low -> high): built-in defaults < this file < environment vars.
## See the "Environment overrides" section at the bottom for the env equivalents.

# version = 1

## ─── [segments] — show / hide individual segments ────────────────────────────
## This block MERGES over the defaults: uncomment a single line to flip just that
## one segment; every other segment keeps its built-in default. Each value below
## is the current default. (`path` and `context` are "pinned" — when the terminal
## is too narrow for everything, they survive the trim; setting them false still
## hides them entirely.)
# [segments]
## identity line (top row)
# path = true          # 📂 working directory, ~-relative   (pinned)
# branch = true        # git branch name
# dirty = true         # working-tree dirty marker
# worktree = true      # ⎇ active linked-worktree name (struck ⎇ wt on main)
# todo = true          # 📝 current TODO  (📝 in-progress / ⏸ pending)
## model line (middle row)
# model = true         # active model name (e.g. Opus)
# time_ago = true      # time since the session's first message
# clock = true         # ⏰ current wall-clock time
# effort = true        # 🧠 reasoning-effort ladder + level ([auto] when auto)
# lines = true         # 📃 lines added / removed this session
# cost = false         # 🪙 session cost in USD            (OFF by default)
# total_time = true    # 💬 total session duration
# api_time = true      # 📡 cumulative API response time
## diagnostics line (bottom row)
# render_time = true   # ⏱ status-line's own render time, SLO/SLA-colored
# slowest = true       # 🐌 slowest single segment this render (name + duration)
# dimensions = false   # terminal size cols×lines (? if assumed)  (debug; OFF by default)
# context = true       # 📊 context-window % used (and max) (pinned)
# chat_size = true     # 💾 transcript file size on disk
# memory = true        # 🧮 status-line process memory (RSS)
# rate_limits = true   # ⚡ rate-limit buckets with reset time

## ─── [[line]] — full layout override ─────────────────────────────────────────
## ALL-OR-NOTHING (unlike [segments], which merges): if you uncomment ANY [[line]]
## block you must uncomment them ALL, or the omitted segments are silently dropped.
## `min_rows` gates a row by terminal height (the row is skipped on shorter
## terminals). Segment order is left -> right priority — the leftmost segments are
## kept first when horizontal space is tight. The three blocks below ARE the
## current default layout; copy and reorder to taste.
# [[line]]
# min_rows = 0
# segments = ["path", "branch", "worktree", "dirty", "todo"]
# [[line]]
# min_rows = 20
# segments = ["model", "time_ago", "clock", "effort", "lines", "cost", "total_time", "api_time"]
# [[line]]
# min_rows = 30
# segments = ["render_time", "dimensions", "context", "chat_size", "memory", "rate_limits", "slowest"]

## ─── [git] — git probe tuning ────────────────────────────────────────────────
## Behaviour knobs for the git queries behind the `branch` / `dirty` /
## `worktree` segments. This block MERGES over the defaults.
## NOTE: linked-worktree display is now the `worktree` segment (see [segments]
## above), ON by default — toggle it there, not here. A legacy `[git] worktree =
## true/false` key (and the old CC_AI_KIT_GIT_WORKTREE env) is silently ignored.
# [git]
# cache_ttl = 5        # seconds the worktree probe is cached (branch/dirty stay
#                      # fresh). Precedence: default 5 < this < env CC_AI_KIT_GIT_TTL.

## ─── [external] — drop-in segment providers ──────────────────────────────────
## Add a new status-line segment WITHOUT editing status-line.py: drop an
## executable into the segments directory below. Each provider:
##   * carries a header in its first 10 lines:
##       # ai-kit-segment: line=<N> (after=<key>|before=<key>|start|end) [id=<slug>] [timeout=<s>] [ttl=<s>]
##   * receives the status JSON on stdin (plus a "segment" block with avail_cols /
##     id / line / position) and the AI_KIT_SEGMENT_* env mirror, with cwd set to
##     the workspace directory;
##   * prints ONE line (SGR color allowed; other control sequences are stripped),
##     sized to the AI_KIT_SEGMENT_COLS budget — or nothing to omit itself.
## Discovered providers are ENABLED BY DEFAULT; disable one explicitly via
## [segments] <id> = false (or CC_AI_KIT_SEGMENT_<ID>=0). A ready-to-copy sample
## ships at examples/segments/sysmem (system available memory). Each value below
## is the current default.
# [external]
# ttl = 10                              # default cache TTL (s); env CC_AI_KIT_EXTERNAL_TTL
# dir = "~/.config/ai-kit/segments"     # providers directory; env CC_AI_KIT_SEGMENTS_DIR

## ─── color grammar (used by [palette] and [ramp.*] values) ───────────────────
## A color value is one of:
##   * a palette NAME            e.g. RED, BLUE, ORANGE
##   * a raw SGR parameter list  e.g. 38;5;208   (advanced; "xy;x;ab" form — the
##                               part between "ESC[" and "m", no "\033[" / "m")
##   * a hex color               e.g. #3399ff  (#rgb / #rrggbb / #rrggbbaa;
##                                              an accidental IDE alpha is dropped)
## Any of these may carry +bold / +dim / +italic / +underline modifiers, e.g.
## RED+bold, #3399ff+bold. Hex needs a truecolor terminal; italic/underline vary.
## [palette] MERGES over the defaults (override just the names you list);
## [ramp.X] REPLACES that whole ramp (list every band you want).

## ─── [palette] — named colors (each value below IS the default) ──────────────
## This block MERGES over the defaults: uncomment only the colors you want to
## change. The default blue is the lightened 256-color shade (1;34 reads purple
## on some terminals). Each line below is the current default.
# [palette]
# GREY = "90"                      # dim / secondary text, ladders, brackets
# WHITE = "97"                     # time-ago, lowest context band
# CYAN = "36"                      # model name, low effort
# GREEN = "32"                     # added lines, healthy bands
# RED = "31"                       # removed lines, high-severity bands
# YELLOW = "33"                    # high effort, mid bands
# MAGENTA = "35"                   # top chat-size band
# ORANGE = "38;5;208"              # xhigh effort, warning bands
# BLUE = "38;5;39"                 # path, medium effort (lightened 256-color blue)
# LIGHTBLUE = "38;5;75"            # cornflower — chat-size ramp band 3 (distinct from BLUE)
# MAGENTA_DARK = "38;5;90"         # dark/gothic — top context band (>= 50%)

## ─── [ramp.context] — context-window % -> color (whole-ramp replace) ─────────
## A ramp maps a value to a color by ascending threshold: the band whose ceil
## the value is first strictly below wins. [ramp.X] REPLACES the whole ramp, so
## list every band you want. Each line below is the current default.
# [ramp.context]
# 10 = "WHITE"
# 15 = "CYAN"
# 20 = "BLUE"
# 25 = "GREEN"
# 30 = "YELLOW"
# 40 = "ORANGE+bold"
# 50 = "RED+bold"
# inf = "MAGENTA_DARK+bold"

## ─── [ramp.rate] — rate-limit % -> color ────────────────────────────────────
# [ramp.rate]
# 50 = "GREEN"
# 80 = "YELLOW"
# inf = "RED+bold"

## ─── [ramp.chat_size] — transcript bytes -> color (k/M/G suffixes) ──────────
## Byte thresholds must be quoted strings ("512k", "1M", …) so they parse as
## valid TOML keys; "inf" is the catch-all top band.
# [ramp.chat_size]
# "512k" = "WHITE"
# "1M" = "CYAN"
# "2M" = "LIGHTBLUE"
# "3M" = "GREEN"
# "4M" = "YELLOW"
# "5M" = "ORANGE"
# "10M" = "RED+bold"
# inf = "MAGENTA"

## ─── [ramp.render_time] — self-render time -> color (ns/µs/ms/s suffixes) ─────
## SLO/SLA thresholds for the status line's own run time, as quoted time strings
## ("50ms", "2s", "500us"/"500µs", "100ns"); "inf" is the catch-all top band.
## Default: GREEN within the 50ms SLO, YELLOW up to the 150ms SLA, RED+bold beyond.
# [ramp.render_time]
# "50ms" = "GREEN"
# "150ms" = "YELLOW"
# inf = "RED+bold"

## ─── [ramp.slowest] — slowest single segment's time -> color (ns/µs/ms/s) ─────
## The ONE shared SLO/SLA ramp the `slowest` segment colors by (no per-segment
## bands). Same time-string grammar as [ramp.render_time]; tighter thresholds
## since it grades a single builder, not the whole render.
## Default: GREEN within the 15ms SLO, YELLOW up to the 40ms SLA, RED+bold beyond.
# [ramp.slowest]
# "15ms" = "GREEN"
# "40ms" = "YELLOW"
# inf = "RED+bold"

## ─── Environment overrides (set in your shell, not this file) ─────────────────
## These win over everything in this file — handy for per-session tweaks:
##   CC_AI_KIT_CONFIG=/path/to/statusline.toml   # use a config file elsewhere
##   CC_AI_KIT_SEGMENT_<KEY>=<bool>              # toggle one segment; KEY is the
##                                                 upper-cased segment name, e.g.
##                                                 CC_AI_KIT_SEGMENT_COST=1
##   bool truthy: 1 true t y yes on   bool falsy: 0 false f n no off
##   CC_AI_KIT_SEGMENTS_DIR=/path/to/segments   # external providers directory
##   CC_AI_KIT_EXTERNAL_TTL=10                  # external-segment cache TTL (s)
##
## Inspect & validate the resolved config:
##   python3 tools/status-line.py --print-config   # resolved config as JSON
##   python3 tools/status-line.py --check          # validate this file
##   python3 tools/status-line.py --help           # full flag + env reference
